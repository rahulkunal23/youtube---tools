
<!DOCTYPE html>
<html>
<head>
  <title>Free PinBoard</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    body{
      margin:0;
      font-family: Arial, sans-serif;
      background:#111;
      color:white;
    }
    header{
      background:#e60023;
      padding:15px;
      text-align:center;
      font-size:22px;
      font-weight:bold;
    }
    .grid{
      column-count:2;
      column-gap:10px;
      padding:10px;
    }
    .grid img{
      width:100%;
      margin-bottom:10px;
      border-radius:10px;
    }
    @media(min-width:768px){
      .grid{
        column-count:4;
      }
    }
  </style>
</head>
<body>

<header>🔥 My PinBoard</header>

<div class="grid">
  <img src="https://source.unsplash.com/400x600?nature" />
  <img src="https://source.unsplash.com/400x500?technology" />
  <img src="https://source.unsplash.com/400x700?cars" />
  <img src="https://source.unsplash.com/400x550?travel" />
  <img src="https://source.unsplash.com/400x650?food" />
  <img src="https://source.unsplash.com/400x500?fitness" />
  <img src="https://source.unsplash.com/400x600?animals" />
  <img src="https://source.unsplash.com/400x550?fashion" />
</div>

</body>
</html>
